# ============================================================
# TopBins Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# ── Supabase (get these from: Project Settings → API) ──────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# ── Google Gemini AI (for TacticalAI component) ────────────
VITE_GEMINI_API_KEY=your-gemini-api-key-here

# ── Server-side only (Python scraper / CI) ─────────────────
# These are NOT prefixed with VITE_ — never expose to the browser.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key-here
